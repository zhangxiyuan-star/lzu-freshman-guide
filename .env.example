# ============================================
# 公开环境变量（VITE_ 前缀，会打包到前端）
# 这些变量可以在前端代码中通过 import.meta.env.VITE_XXX 访问
# ============================================

# 站点名称
VITE_SITE_NAME=兰州大学新生入学手册
VITE_SITE_URL=https://zhangxiyuan-star.github.io/lzu-freshman-guide/

# 官方链接（公开配置）
VITE_OFFICIAL_MAIN=https://www.lzu.edu.cn/
VITE_OFFICIAL_SERVICE=https://www.lzu.edu.cn/zjld/fwrk.htm
VITE_OFFICIAL_MAP=https://www.lzu.edu.cn/zjld/xydt.htm
VITE_OFFICIAL_CONTACT=https://www.lzu.edu.cn/zjld/lxwm.htm
VITE_OFFICIAL_MY=https://my.lzu.edu.cn/
VITE_OFFICIAL_JWC=https://jwc.lzu.edu.cn/
VITE_OFFICIAL_XGB=https://xgb.lzu.edu.cn/
VITE_OFFICIAL_HQ=https://hq.lzu.edu.cn/
VITE_OFFICIAL_LIB=https://lib.lzu.edu.cn/
VITE_OFFICIAL_ZSB=https://zsb.lzu.edu.cn/

# 信息核验日期
VITE_VERIFIED_DATE=2026-07-16

# ============================================
# 秘密环境变量（无前缀，仅服务端可用）
# 这些变量只能在 Vercel Serverless Function 中访问
# 不要在前端代码中使用！在 Vercel 后台配置
# ============================================

# 示例：第三方 API 密钥（仅服务端使用）
# API_SECRET_KEY=your-secret-key-here

# 示例：数据库连接串
# DATABASE_URL=your-db-connection-string

# 示例：消息墙后端 API 地址（如果以后加后端）
# MESSAGE_WALL_API_URL=https://your-backend-api.com
